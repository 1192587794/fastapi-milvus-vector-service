APP_NAME=Milvus FastAPI
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Supported modes:
# 1. local file path, e.g. ./data/milvus_demo.db
# 2. HTTP endpoint, e.g. http://localhost:19530
MILVUS_URI=./data/milvus_demo.db
MILVUS_TOKEN=
MILVUS_DB_NAME=default

MILVUS_COLLECTION=documents
MILVUS_VECTOR_DIMENSION=64
MILVUS_METRIC_TYPE=COSINE
MILVUS_CONSISTENCY_LEVEL=Bounded
MILVUS_DROP_EXISTING_ON_START=false

# Ollama embedding
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Text chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# File upload
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=[".pdf",".docx"]

# LLM / RAG
# LLM_PROVIDER: ollama 或 openai
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=qwen2.5:7b
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_TOP_K=5
RAG_RECALL_MULTIPLIER=4

# 查询改写（Query Rewriting）
# 开启后，会在召回前用 LLM 将口语化问题改写为更适合检索的形式
# 示例："这玩意儿咋用" -> "如何使用 Milvus 向量数据库"
ENABLE_QUERY_REWRITING=false
# QUERY_REWRITING_CONTEXT_TURNS: 查询改写时使用的对话历史轮数（默认 3）
# QUERY_REWRITING_CONTEXT_TURNS=3
# QUERY_REWRITING_KB_TOPIC: 知识库主题描述，帮助 LLM 理解领域上下文
# 示例："这是一个关于 Milvus 向量数据库的技术文档知识库"
# QUERY_REWRITING_KB_TOPIC=

# 混合召回（BM25 + 向量）+ RRF 粗排
ENABLE_HYBRID_RECALL=true
HYBRID_RECALL_ALPHA=0.5

# 精排（Cross-Encoder Reranker）
# 首次开启时会自动下载模型（约 80MB），后续使用本地缓存
ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Redis 多轮对话存储
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600
